# LLM provider
DASHSCOPE_API_KEY=your_dashscope_api_key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/
OPENAI_CHAT_MODEL=qwen-plus
OPENAI_CHAT_TEMPERATURE=0.7
OPENAI_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/
OPENAI_EMBEDDING_MODEL=text-embedding-v4
OPENAI_EMBEDDING_DIMENSION=1024

# MySQL
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/dodo?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=GMT%2B8
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

# MinIO
MINIO_URL=http://127.0.0.1:9000/
MINIO_ENDPOINT=http://127.0.0.1:9000/
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=dodo-agent

# PgVector
PGVECTOR_HOST=127.0.0.1
PGVECTOR_PORT=5432
PGVECTOR_DATABASE=vector_store
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=your_pgvector_password

# Search / image generation
TAVILY_API_KEY=your_tavily_api_key
TAVILY_MCP_URL=https://mcp.tavily.com/mcp/
GRSAI_NANOBANANA_API_KEY=your_image_api_key

# Optional skills directory
DODO_SKILLS_DIR=/path/to/skills
